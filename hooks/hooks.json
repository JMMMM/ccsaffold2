{
  "description": "ccsaffold plugin hooks: session logging and auto-learning",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/session-logger.js\""
          }
        ],
        "description": "Session Log: 记录用户输入到conversation.txt"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(?!Read|Grep|Glob|WebSearch|WebFetch|TaskOutput|mcp__|4_5v_mcp__|context7|web-reader|zai-mcp-server).*$",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/session-logger.js\""
          }
        ],
        "description": "Session Log: 记录AI工具调用（排除只读查询类工具）"
      },
      {
        "matcher": "mcp__web-reader__webReader|mcp__web_reader__webReader",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/web-cache-after.js\"",
            "timeout": 30
          }
        ],
        "description": "Web-Cache-After: 自动缓存网站内容并生成skill"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/auto-learning.js\""
          }
        ],
        "description": "Auto-learning: 会话结束时自动分析学习内容并生成skill"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__web-reader__webReader|mcp__web_reader__webReader",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/web-cache-before.js\""
          }
        ],
        "description": "Web-Cache-Before: 检查网站缓存，优先使用已缓存内容"
      }
    ]
  }
}
